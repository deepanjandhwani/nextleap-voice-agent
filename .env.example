# Copy to `.env` and fill in values. Do not commit `.env`.

# --- HTTP server (python -m advisor_scheduler) ---
# Default is 127.0.0.1:8000. If port 8000 is busy, use e.g. 8001 and match PUBLIC_BASE_URL.
# ADVISOR_API_HOST=127.0.0.1
# ADVISOR_API_PORT=8001
# Or: PORT=8001  (same as ADVISOR_API_PORT; common on PaaS)

# --- Core ---
# Production: your public HTTPS origin (Vercel, Railway, Fly, Cloud Run, etc.). The assistant
# shares PUBLIC_BASE_URL/secure-details?code=NL-XXXX (served by this app or the public/ mirror on Vercel).
# Vercel example: PUBLIC_BASE_URL=https://your-project.vercel.app
PUBLIC_BASE_URL=https://your-app.example.com
# Local dev (uvicorn default port):
# PUBLIC_BASE_URL=http://127.0.0.1:8000
#
# Optional: path on this app (default is /secure-details if unset):
# SECURE_DETAILS_BASE_URL=/secure-details
#
# Alternative: omit PUBLIC_BASE_URL and set a full URL (not https://example.com/...):
# SECURE_DETAILS_BASE_URL=https://your-app.example.com/secure-details
ADVISOR_EMAIL=advisor-team@example.com
SESSION_TIMEOUT_MINUTES=20
# Optional: TTS line replacing the spoken secure-link sentence (voice channel).
# VOICE_SECURE_FOLLOWUP_SPOKEN=Your tentative booking is set. A secure link...

# --- Gemini (Phase 1+ chat) ---
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2

# --- Deepgram voice (server-side STT/TTS) ---
# Required for POST /voice-turn and the hold-to-talk browser UI.
# DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=nova-3
DEEPGRAM_TTS_MODEL=aura-2-asteria-en
DEEPGRAM_LANGUAGE=en-IN
DEEPGRAM_TTS_ENCODING=mp3
# For mp3/opus, Deepgram fixes the output rate; this is only used for encodings like linear16.
DEEPGRAM_TTS_SAMPLE_RATE=24000
# DEEPGRAM_REQUEST_TIMEOUT_SECONDS=30

# --- Phase 2: Google Workspace via in-repo Python FastMCP server ---
USE_MCP=false

# Required when USE_MCP=true: resource IDs from Google Calendar / Sheets.
GOOGLE_CALENDAR_ID=
GOOGLE_SHEETS_SPREADSHEET_ID=
# Tab name for append-only event log (default matches spec).
GOOGLE_SHEETS_TAB=Advisor Pre-Bookings

# FastMCP Client transport for the in-repo Google server. Optional: when
# unset, the adapters auto-launch the in-repo server module via the
# current Python interpreter. Set this to a JSON file (the one written
# by `scripts/setup_google_mcp.py`), inline JSON, or a stdio command.
# MCP_GOOGLE_CONFIG=
#
# Serverless deploys (Vercel): paste the JSON contents into env vars instead
# of pointing at local files. GOOGLE_OAUTH_TOKEN_JSON is the important one for
# non-interactive runtime; generate it locally with `python scripts/setup_google_mcp.py`.
# GOOGLE_OAUTH_CREDENTIALS_JSON={"installed":{...}}
# GOOGLE_OAUTH_TOKEN_JSON={"token":"...","refresh_token":"...",...}

# Override only if pointing at a custom server with different tool labels.
# MCP_TOOL_CALENDAR_CREATE_HOLD=calendar_create_hold
# MCP_TOOL_CALENDAR_UPDATE_HOLD=calendar_update_hold
# MCP_TOOL_CALENDAR_DELETE_HOLD=calendar_delete_hold
# MCP_TOOL_CALENDAR_FREEBUSY=calendar_get_freebusy
# MCP_TOOL_SHEETS_APPEND_PREBOOKING=sheets_append_prebooking
# MCP_TOOL_SHEETS_LIST_PREBOOKINGS=sheets_list_prebookings
# MCP_TOOL_GMAIL_CREATE_DRAFT=gmail_create_draft

# Working hours in IST for deriving 30-minute slots from free/busy (defaults: 9–18).
# ADVISOR_SLOT_START_HOUR=9
# ADVISOR_SLOT_END_HOUR=18

# --- Live MCP smoke tests (pytest) ---
# MCP_LIVE_TEST=1
